<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShadowLink - النظام التفاعلي المتكامل</title>
    <style>
        :root {
            --bg-dark: #0b0c10;
            --bg-card: #1f2833;
            --text-light: #ffffff;
            --text-gray: #c5c6c7;
            --accent-gold: #c5a059;
            --chat-bubble-in: #2b3a4a;
            --chat-bubble-out: #c5a059;
            --google-color: #db4437;
            --microsoft-color: #00a4ef;
            --messenger-color: #006aff;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        /* ==================== 1. واجهة تسجيل الدخول ==================== */
        #loginWrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
            height: 100%;
            position: absolute;
            z-index: 10;
            background-color: var(--bg-dark);
        }

        .login-container {
            background-color: var(--bg-card);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7);
            width: 100%;
            max-width: 400px;
            text-align: center;
            box-sizing: border-box;
        }

        .login-container h2 {
            margin-bottom: 10px;
            color: var(--accent-gold);
            font-size: 2rem;
        }

        .login-container p {
            color: var(--text-gray);
            font-size: 0.9rem;
            margin-bottom: 25px;
        }

        .input-group {
            margin-bottom: 15px;
            text-align: right;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-gray);
            font-size: 0.9rem;
        }

        .input-group input {
            width: 100%;
            padding: 12px;
            background-color: var(--bg-dark);
            border: 1px solid #333;
            border-radius: 8px;
            color: #fff;
            font-size: 1rem;
            outline: none;
            box-sizing: border-box;
        }

        .input-group input:focus {
            border-color: var(--accent-gold);
        }

        .error-message {
            color: #ff4d4d;
            font-size: 0.85rem;
            margin-bottom: 10px;
            text-align: right;
            display: none;
        }

        .btn-login {
            width: 100%;
            padding: 12px;
            background-color: var(--accent-gold);
            color: var(--bg-dark);
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-login:hover {
            background-color: #e0b869;
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 25px 0;
            color: var(--text-gray);
            font-size: 0.85rem;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #333;
        }

        .divider:not(:empty)::before { margin-left: .25em; }
        .divider:not(:empty)::after { margin-right: .25em; }

        .social-login-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .btn-social {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            color: #fff;
            font-size: 0.95rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-google { background-color: var(--google-color); }
        .btn-google:hover { background-color: #c53727; }
        .btn-microsoft { background-color: var(--microsoft-color); }
        .btn-microsoft:hover { background-color: #008ccb; }
        .btn-messenger { background-color: var(--messenger-color); }
        .btn-messenger:hover { background-color: #0056ce; }

        /* ==================== 2. واجهة التطبيق الرئيسية ==================== */
        #appWrapper {
            display: none;
            width: 100%;
            height: 100vh;
        }

        .main-app {
            display: flex;
            width: 100%;
            height: 100%;
        }

        .sidebar {
            width: 350px;
            background-color: var(--bg-card);
            display: flex;
            flex-direction: column;
            border-left: 1px solid #111;
        }

        .sidebar-header {
            padding: 20px;
            border-bottom: 1px solid #111;
        }

        .sidebar-header h2 {
            margin: 0 0 15px 0;
            color: var(--accent-gold);
        }

        .search-box {
            display: flex;
            background: var(--bg-dark);
            border-radius: 20px;
            padding: 5px 15px;
            align-items: center;
        }

        .search-box input {
            background: transparent;
            border: none;
            color: #fff;
            width: 100%;
            padding: 8px;
            outline: none;
        }

        .chat-list {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
        }

        .chat-item {
            display: flex;
            align-items: center;
            padding: 12px;
            border-radius: 10px;
            cursor: pointer;
            margin-bottom: 8px;
            background: rgba(255, 255, 255, 0.02);
            transition: 0.2s;
        }

        .chat-item.active {
            background: rgba(197, 160, 89, 0.15);
            border-right: 3px solid var(--accent-gold);
        }

        .chat-item:hover {
            background: rgba(255, 255, 255, 0.08);
        }

        .chat-avatar {
            width: 45px;
            height: 45px;
            background: var(--accent-gold);
            border-radius: 50%;
            margin-left: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-weight: bold;
        }

        .chat-info {
            flex: 1;
        }

        .chat-info .name {
            font-weight: bold;
            color: #fff;
            margin-bottom: 5px;
        }

        .chat-info .preview {
            font-size: 0.85rem;
            color: #888;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }

        .chat-window {
            flex: 1;
            display: flex;
            flex-direction: column;
            background-color: var(--bg-dark);
        }

        .chat-window-header {
            padding: 20px;
            background-color: var(--bg-card);
            color: #fff;
            font-weight: bold;
            border-bottom: 1px solid #111;
        }

        .messages-container {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .message {
            max-width: 60%;
            padding: 12px 18px;
            border-radius: 15px;
            line-height: 1.4;
            word-wrap: break-word;
        }

        .message.incoming {
            background-color: var(--chat-bubble-in);
            color: #fff;
            align-self: flex-start;
            border-top-right-radius: 2px;
        }

        .message.outgoing {
            background-color: var(--chat-bubble-out);
            color: var(--bg-dark);
            align-self: flex-end;
            border-top-left-radius: 2px;
            font-weight: 500;
        }

        /* مؤشر جاري الكتابة التفاعلي */
        .typing-indicator {
            display: none;
            align-self: flex-start;
            background-color: var(--chat-bubble-in);
            padding: 12px 18px;
            border-radius: 15px;
            border-top-right-radius: 2px;
        }

        .dots {
            display: flex;
            gap: 5px;
            align-items: center;
            height: 10px;
        }

        .dots span {
            width: 8px;
            height: 8px;
            background-color: var(--text-gray);
            border-radius: 50%;
            animation: bounce 1.4s infinite ease-in-out both;
        }

        .dots span:nth-child(1) { animation-delay: -0.32s; }
        .dots span:nth-child(2) { animation-delay: -0.16s; }

        @keyframes bounce {
            0%, 80%, 100% { transform: scale(0); }
            40% { transform: scale(1); }
        }

        .input-area {
            padding: 20px;
            background-color: var(--bg-card);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .input-area input {
            flex: 1;
            background: var(--bg-dark);
            border: 1px solid #333;
            padding: 12px;
            color: #fff;
            border-radius: 25px;
            outline: none;
        }

        .btn-action {
            background: var(--accent-gold);
            color: var(--bg-dark);
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>

    <!-- 1. شاشة تسجيل الدخول المسبقة -->
    <div id="loginWrapper">
        <div class="login-container">
            <h2>ShadowLink</h2>
            <p>يرجى تسجيل الدخول لتفعيل كافة مزايا التطبيق الحية.</p>

            <form id="loginForm">
                <div class="input-group">
                    <label>الاسم</label>
                    <input type="text" id="username" placeholder="أدخل اسمك هنا" required>
                </div>
                
                <div class="input-group">
                    <label>كلمة المرور</label>
                    <input type="password" id="password" placeholder="أدخل كلمة المرور الافتراضية 1234" required>
                </div>

                <div class="error-message" id="errorMsg">كلمة المرور غير صحيحة! جرب 1234</div>

                <button type="submit" class="btn-login">تسجيل الدخول</button>
            </form>

            <div class="divider">أو تفعيل فوري عبر المنصات الحليفة</div>

            <div class="social-login-group">
                <button class="btn-social btn-google" onclick="triggerSocialLogin('Google')">
                    تسجيل الدخول بواسطة Google
                </button>
                <button class="btn-social btn-microsoft" onclick="triggerSocialLogin('Microsoft')">
                    تسجيل الدخول بواسطة Microsoft
                </button>
                <button class="btn-social btn-messenger" onclick="triggerSocialLogin('Messenger')">
                    تسجيل الدخول بواسطة Messenger
                </button>
            </div>
        </div>
    </div>

    <!-- 2. واجهة التطبيق الرئيسية الشغالة بالكامل -->
    <div id="appWrapper">
        <div class="main-app">
            <div class="sidebar">
                <div class="sidebar-header">
                    <h2>ShadowLink</h2>
                    <!-- شريط البحث الحي الشغال -->
                    <div class="search-box">
                        <input type="text" id="chatSearch" placeholder="بحث فوري عن صديق..." oninput="filterChats()" />
                    </div>
                </div>

                <!-- قائمة المحادثات القابلة للتبديل والفلترة -->
                <div class="chat-list" id="chatListContainer">
                    <!-- سيتم بناؤها ديناميكياً بواسطة البرمجة لتشتغل بالكامل -->
                </div>
            </div>

            <div class="chat-window">
                <div class="chat-window-header" id="activeChatHeader">
                    المحادثة المفتوحة
                </div>
                
                <!-- منطقة الرسائل التفاعلية -->
                <div class="messages-container" id="messagesContainer">
                    <!-- الرسائل تظهر هنا تلقائياً -->
                </div>

                <!-- مؤشر جاري الكتابة المتحرك -->
                <div class="typing-indicator" id="typingIndicator">
                    <div class="dots">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                </div>

                <!-- إرسال الرسائل الحية -->
                <form class="input-area" id="messageForm" onsubmit="sendMessage(event)">
                    <button type="button" class="btn-action">+</button>
                    <input type="text" id="messageInput" placeholder="اكتب رسالة تفاعلية..." autocomplete="off"/>
                    <button type="submit" class="btn-action">◀</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        // قاعدة البيانات المؤقتة للمحادثات والردود التلقائية لتشغيل كل شيء
        const chatsData = {
            russia: {
                name: "الاتصال الصديق (روسيا)",
                avatar: "RU",
                messages: [
                    { type: 'incoming', text: "مرحباً بك! الخطوط مؤمنة بالكامل بيننا." },
                    { type: 'outgoing', text: "ممتاز، هل كل الأنحاء مفعّلة الآن؟" },
                    { type: 'incoming', text: "نعم، النظام التفاعلي يعمل بالكامل وجاهز لتلقي رسائلك." }
                ],
                replies: [
                    "علم، نقوم بمراقبة الخوادم الآن للتأكد من استقرارها.",
                    "تم تحديث بروتوكولات البحث الفوري بنجاح.",
                    "مؤشرات الاتصال مستقرة تماماً في جميع الأنحاء الملكية."
                ]
            },
            advisor: {
                name: "مستشار القصر",
                avatar: "م",
                messages: [
                    { type: 'incoming', text: "جلالتك، هل اعتمدت تصميم نظام ShadowLink الجديد؟" }
                ],
                replies: [
                    "أمرك مطاع، تم حفظ الملفات على جهازك الـ Toshiba.",
                    "كل الأنحاء جاهزة ومفعلة بناءً على توجيهاتك المباشرة.",
                    "سأقوم بجدولة التحديث القادم فوراً."
                ]
            }
        };

        let currentChatKey = 'russia';
        let replyIndex = 0;

        // عناصر الواجهة
        const loginForm = document.getElementById('loginForm');
        const usernameInput = document.getElementById('username');
        const passwordInput = document.getElementById('password');
        const errorMsg = document.getElementById('errorMsg');
        const loginWrapper = document.getElementById('loginWrapper');
        const appWrapper = document.getElementById('appWrapper');
        const activeChatHeader = document.getElementById('activeChatHeader');
        const chatListContainer = document.getElementById('chatListContainer');
        const messagesContainer = document.getElementById('messagesContainer');
        const messageInput = document.getElementById('messageInput');
        const typingIndicator = document.getElementById('typingIndicator');
        const chatSearch = document.getElementById('chatSearch');

        // دالة تفعيل التطبيق الكامل
        function unlockFullApp(userTitle) {
            loginWrapper.style.display = 'none';
            appWrapper.style.display = 'block';
            renderChatList();
            loadChat(currentChatKey);
        }

        // تسجيل الدخول العادي
        loginForm.addEventListener('submit', function(event) {
            event.preventDefault();
            if (passwordInput.value === '1234') {
                errorMsg.style.display = 'none';
                unlockFullApp(usernameInput.value);
            } else {
                errorMsg.style.display = 'block';
            }
        });

        // تسجيل الدخول عبر المنصات الخارجية
        function triggerSocialLogin(platformName) {
            unlockFullApp(`مستخدم عبر ${platformName}`);
        }

        // بناء قائمة الأصدقاء بشكل ديناميكي
        function renderChatList() {
            chatListContainer.innerHTML = '';
            Object.keys(chatsData).forEach(key => {
                const chat = chatsData[key];
                const lastMsg = chat.messages[chat.messages.length - 1];
                const previewText = lastMsg ? lastMsg.text : '';
                
                const activeClass = key === currentChatKey ? 'active' : '';

                const itemHtml = `
                    <div class="chat-item ${activeClass}" id="item-${key}" onclick="switchChat('${key}')">
                        <div class="chat-avatar">${chat.avatar}</div>
                        <div class="chat-info">
                            <div class="name">${chat.name}</div>
                            <div class="preview">${previewText}</div>
                        </div>
                    </div>
                `;
                chatListContainer.insertAdjacentHTML('beforeend', itemHtml);
            });
        }

        // التبديل بين المحادثات
        function switchChat(key) {
            currentChatKey = key;
            renderChatList();
            loadChat(key);
        }

        // تحميل رسائل المحادثة النشطة
        function loadChat(key) {
            const chat = chatsData[key];
            activeChatHeader.innerText = `المحادثة النشطة: ${chat.name}`;
            messagesContainer.innerHTML = '';
            
            chat.messages.forEach(msg => {
                const msgHtml = `<div class="message ${msg.type}">${msg.text}</div>`;
                messagesContainer.insertAdjacentHTML('beforeend', msgHtml);
            });
            scrollToBottom();
        }

        // إرسال رسالة حية
        function sendMessage(event) {
            event.preventDefault();
            const text = messageInput.value.trim();
            if (!text) return;

            // 1. إضافة رسالة المستخدم
            chatsData[currentChatKey].messages.push({ type: 'outgoing', text: text });
            messageInput.value = '';
            loadChat(currentChatKey);
            renderChatList();

            // 2. تفعيل مؤشر "جاري الكتابة..." مثل ماسنجر تماماً
            setTimeout(() => {
                typingIndicator.style.display = 'block';
                scrollToBottom();
            }, 500);

            // 3. استقبال الرد التلقائي الحي بعد ثانيتين
            setTimeout(() => {
                typingIndicator.style.display = 'none';
                
                const currentReplies = chatsData[currentChatKey].replies;
                const replyText = currentReplies[replyIndex % currentReplies.length];
                replyIndex++;

                chatsData[currentChatKey].messages.push({ type: 'incoming', text: replyText });
                loadChat(currentChatKey);
                renderChatList();
            }, 2500);
        }

        // فلترة وقفل البحث الفوري الحي
        function filterChats() {
            const query = chatSearch.value.toLowerCase();
            Object.keys(chatsData).forEach(key => {
                const item = document.getElementById(`item-${key}`);
                if (item) {
                    const name = chatsData[key].name.toLowerCase();
                    if (name.includes(query)) {
                        item.style.display = 'flex';
                    } else {
                        item.style.display = 'none';
                    }
                }
            });
        }

        function scrollToBottom() {
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
    </script>
</body>
</html>
